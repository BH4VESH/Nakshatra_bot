doctype html
html
  head
    title Trading Dashboard Login

    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    style.
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
      }

      body {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: linear-gradient(135deg, #0f172a, #1e293b);
      }

      .login-card {
        width: 100%;
        max-width: 400px;
        background: white;
        padding: 35px;
        border-radius: 15px;
        box-shadow: 0 15px 40px rgba(0,0,0,0.25);
      }

      .logo {
        text-align: center;
        font-size: 28px;
        font-weight: bold;
        color: #2563eb;
        margin-bottom: 10px;
      }

      .subtitle {
        text-align: center;
        color: #666;
        margin-bottom: 25px;
      }

      .form-group {
        margin-bottom: 18px;
      }

      label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        color: #333;
      }

      input {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-size: 15px;
      }

      input:focus {
        outline: none;
        border-color: #2563eb;
      }

      button {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: #2563eb;
        color: white;
        font-size: 16px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
      }

      button:hover {
        background: #1d4ed8;
      }

      .error {
        background: #fee2e2;
        color: #dc2626;
        padding: 10px;
        border-radius: 8px;
        margin-bottom: 15px;
        text-align: center;
      }

      .footer {
        margin-top: 20px;
        text-align: center;
        color: #888;
        font-size: 13px;
      }

  body

    .login-card

      .logo
        |Login Dashboard

      .subtitle
        | Login to access trading insights

      if error
        .error= error

      form(method="POST" action="/login")

        .form-group
          label Username
          input(
            type="text"
            name="username"
            placeholder="Enter username"
            required
          )

        .form-group
          label Password
          input(
            type="password"
            name="password"
            placeholder="Enter password"
            required
          )

        button(type="submit")
          | Login

      .footer
        | Secure Trading Dashboard